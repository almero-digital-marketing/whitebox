{
  "name": "whitebox-pro-client",
  "version": "0.2.0",
  "description": "Whitebox browser client core — transport, identity, event emitter, plugin host. Channels (mail, voip, engagement, conversions, consent) ship as separate whitebox-pro-client-plugin-* packages.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./orchestrator": {
      "types": "./dist/orchestrator.d.ts",
      "import": "./dist/orchestrator.js",
      "require": "./dist/orchestrator.cjs"
    },
    "./activity": {
      "types": "./dist/activity.d.ts",
      "import": "./dist/activity.js",
      "require": "./dist/activity.cjs"
    },
    "./consent": {
      "types": "./dist/consent.d.ts",
      "import": "./dist/consent.js",
      "require": "./dist/consent.cjs"
    },
    "./identity": {
      "types": "./dist/identity.d.ts",
      "import": "./dist/identity.js",
      "require": "./dist/identity.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "size": "node scripts/check-size.js",
    "prepublishOnly": "npm run build && npm test"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "whitebox",
    "analytics",
    "tracking",
    "browser"
  ],
  "license": "UNLICENSED",
  "dependencies": {
    "socket.io-client": "^4.7.0"
  },
  "devDependencies": {
    "happy-dom": "^15.0.0",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0",
    "gzip-size": "^7.0.0"
  }
}
